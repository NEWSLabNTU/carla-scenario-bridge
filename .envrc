#!/usr/bin/env bash
# direnv configuration for carla-scenario-bridge
#
# Source order:
#   1. Autoware 1.5.0 (includes ROS 2 Humble + Autoware message packages)
#   2. Local install (SSv2 + bridge config packages + adapter)

# 1. Autoware base
if [ -f /opt/autoware/1.5.0/setup.bash ]; then
    source /opt/autoware/1.5.0/setup.bash
else
    echo "WARNING: /opt/autoware/1.5.0/setup.bash not found." >&2
    echo "  Source your own Autoware setup.bash before building." >&2
    source /opt/ros/humble/setup.bash
fi

# 2. Local install (built by just build — includes SSv2, acb_launch, acb_sensor_kit, etc.)
if [ -f install/setup.bash ]; then
    watch_file install/setup.bash
    source install/setup.bash
fi

export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
